# Copy this file to `api_config.env` and fill in real values locally.
# Do not put real API keys in this example file.

# Primary LLM for event extraction, conflict/update judging, dialogue rewriting,
# and lightweight LLM-as-judge checks.
LLM_PROVIDER=openai
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=replace-with-your-api-key
LLM_MODEL=replace-with-model-name

# Optional stronger model for small-batch audit / final label review.
LLM_AUDIT_MODEL=replace-with-audit-model-name

# Embedding model for retrieval experiments.
EMBEDDING_PROVIDER=openai
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=replace-with-your-api-key
EMBEDDING_MODEL=text-embedding-3-small

# Optional reranker. Leave disabled until needed.
RERANK_PROVIDER=
RERANK_BASE_URL=
RERANK_API_KEY=
RERANK_MODEL=

# Runtime controls.
REQUEST_TIMEOUT_SECONDS=60
MAX_RETRIES=3
